        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.cluster import KMeans\n",
        "from sklearn.metrics import silhouette_score\n",
        "import numpy as np\n",
        "\n",
        "df = pd.read_csv('order_customer.csv')\n",
        "\n",
        "df['order_purchase_timestamp'] = pd.to_datetime(df['order_purchase_timestamp'])\n",
        "\n",
        "print(\"Pedidos únicos:\", df[\"order_id\"].nunique())\n",
        "print(\"Clientes únicos:\", df[\"customer_unique_id\"].nunique())\n",
        "print(\"Preço mínimo:\", df[\"price\"].min())\n",
        "print(\"Preço máximo:\", df[\"price\"].max())\n",
        "\n",
        "reference_date = df[\"order_purchase_timestamp\"].max() + pd.Timedelta(days=1)\n",
        "\n",
        "rfm = df.groupby(\"customer_unique_id\").agg({\n",
        "    \"order_purchase_timestamp\": lambda x: (reference_date - x.max()).days,\n",
        "    \"order_id\": \"nunique\",\n",
        "    \"price\": \"sum\"\n",
        "}).reset_index()\n",
        "\n",
        "rfm.columns = [\"customer_unique_id\", \"recency\", \"frequency\", \"monetary\"]\n",
        "\n",
        "rfm[\"avg_ticket\"] = rfm[\"monetary\"] / rfm[\"frequency\"]\n",
        "\n",
        "rfm_model = rfm[[\"recency\", \"frequency\", \"monetary\", \"avg_ticket\"]].copy()\n",
        "\n",
        "rfm_model[\"frequency\"] = np.log1p(rfm_model[\"frequency\"])\n",
        "rfm_model[\"monetary\"] = np.log1p(rfm_model[\"monetary\"])\n",
        "rfm_model[\"avg_ticket\"] = np.log1p(rfm_model[\"avg_ticket\"])\n",
        "\n",
        "scaler = StandardScaler()\n",
        "rfm_scaled = scaler.fit_transform(rfm_model)\n",
        "\n",
        "inertia = []\n",
        "silhouette_scores = []\n",
        "\n",
        "# amostra para silhouette\n",
        "np.random.seed(42)\n",
        "sample_size = 10000\n",
        "sample_idx = np.random.choice(len(rfm_scaled), size=sample_size, replace=False)\n",
        "rfm_sample = rfm_scaled[sample_idx]\n",
        "\n",
        "for k in range(2, 9):\n",
        "    kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)\n",
        "    labels_full = kmeans.fit_predict(rfm_scaled)\n",
        "    inertia.append(kmeans.inertia_)\n",
        "\n",
        "    labels_sample = kmeans.predict(rfm_sample)\n",
        "    score = silhouette_score(rfm_sample, labels_sample)\n",
        "    silhouette_scores.append(score)\n",
        "\n",
        "for k, score in zip(range(2, 9), silhouette_scores):\n",
        "    print(f\"k={k}: silhouette={score:.4f}\")\n",
        "\n",
        "plt.figure(figsize=(8, 4))\n",
        "plt.plot(range(2, 9), inertia, marker=\"o\")\n",
        "plt.xlabel(\"Número de clusters\")\n",
        "plt.ylabel(\"Inertia\")\n",
        "plt.title(\"Método do cotovelo\")\n",
        "plt.show()\n",
        "\n",
        "kmeans = KMeans(n_clusters=4, random_state=42, n_init=10)\n",
        "rfm[\"cluster\"] = kmeans.fit_predict(rfm_scaled)\n",
        "\n",
        "cluster_summary_simple = rfm.groupby(\"cluster\")[[\"recency\", \"frequency\", \"monetary\", \"avg_ticket\"]].mean().round(2)\n",
        "cluster_counts = rfm[\"cluster\"].value_counts().sort_index()\n",
        "\n",
        "print(cluster_summary_simple)\n",
        "print(\"\\nQuantidade por cluster:\")\n",
        "print(cluster_counts)\n",
        "\n",
        "cluster_names = {\n",
        "    0: \"Clientes Valiosos Recentes\",\n",
        "    1: \"Clientes Recentes de Baixo Valor\",\n",
        "    2: \"Clientes VIP\",\n",
        "    3: \"Clientes Inativos\"\n",
        "}\n",
        "\n",
        "rfm[\"segment\"] = rfm[\"cluster\"].map(cluster_names)\n",
        "\n",
        "segment_summary = rfm.groupby(\"segment\")[[\"recency\", \"frequency\", \"monetary\", \"avg_ticket\"]].mean().round(2)\n",
        "segment_counts = rfm[\"segment\"].value_counts()\n",
        "\n",
        "print(segment_summary)\n",
        "print(\"\\nQuantidade por segmento:\")\n",
        "print(segment_counts)\n",
        "\n",
        "segment_counts.sort_values().plot(kind=\"barh\", figsize=(8,4))\n",
        "plt.xlabel(\"Quantidade de clientes\")\n",
        "plt.ylabel(\"Segmento\")\n",
        "plt.title(\"Distribuição de clientes por segmento\")\n",
        "plt.show()\n",
        "\n",
        "rfm.groupby(\"segment\")[\"monetary\"].mean().sort_values().plot(kind=\"barh\", figsize=(8,4))\n",
        "plt.xlabel(\"Gasto médio\")\n",
        "plt.ylabel(\"Segmento\")\n",
        "plt.title(\"Gasto médio por segmento\")\n",
        "plt.show()"
